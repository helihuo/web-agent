#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DEV_ID="$(printf '%s' "$ROOT" | cksum | awk '{print $1}')"
NAME="${BU_NAME:-default}"

case "$NAME" in
  ""|*[!A-Za-z0-9_-]*)
    echo "invalid BU_NAME: $NAME" >&2
    exit 2
    ;;
esac

export WA_HOME="${WA_HOME:-$ROOT/.web-agent-dev}"
if [ -z "${WA_RUNTIME_DIR:-}" ]; then
  export WA_RUNTIME_DIR="/tmp/wa-dev-$DEV_ID/runtime"
  export WA_RUNTIME_DIR_SHARED="${WA_RUNTIME_DIR_SHARED:-1}"
fi
if [ -z "${WA_TMP_DIR:-}" ]; then
  export WA_TMP_DIR="$WA_HOME/tmp"
  export WA_TMP_DIR_SHARED="${WA_TMP_DIR_SHARED:-1}"
fi

if [ -x "$ROOT/.venv/bin/python" ]; then
  exec "$ROOT/.venv/bin/python" -m web_agent.run "$@"
fi

if command -v uv >/dev/null 2>&1; then
  exec uv --directory "$ROOT" run python -m web_agent.run "$@"
fi

export PYTHONPATH="$ROOT/src${PYTHONPATH:+:$PYTHONPATH}"
exec python3 -m web_agent.run "$@"
