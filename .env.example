# Copy to .env — auto-loaded.
# 支持行内注释：在值后面加 # 即可，引号内的 # 不受影响。
#   例如：KEY=value # 这是注释
#         KEY="value#not_comment"
BROWSER_USE_API_KEY=bu_your_key_here

# 操作流转日志（优先级高于 oplog.jsonc 配置文件）
# WA_OPLOG=1                          # 启用操作日志（1/true 启用，0/false 禁用）
# WA_OPLOG_SCREENSHOT=1               # 将项目原有截图记录到日志（1/true 启用，0/false 禁用）
# WA_OPLOG_DIR=/path/to/oplog         # 自定义日志目录

